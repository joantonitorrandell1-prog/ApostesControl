# Server
PORT=4000
NODE_ENV=development

# Database (local or Neon pooled connection string)
DATABASE_URL=postgresql://postgres:mysecretpassword@localhost:5432/betting_db

# Better Auth (required - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
BETTER_AUTH_SECRET=

# Frontend URL (for CORS + trustedOrigins - use Vercel URL in production)
FRONTEND_URL=https://apostes-control-2b4h.vercel.app

# SMTP (Gmail App Password recommended)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=joantonitorrandell@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM_NAME=Apostes Control
SMTP_FROM_EMAIL=joantonitorrandell@gmail.com
