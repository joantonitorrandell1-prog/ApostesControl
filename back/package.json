{
  "name": "bet-control-backend",
  "version": "1.0.0",
  "description": "Bet Control Hexagonal Backend",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "seed": "tsx scripts/seed.ts",
