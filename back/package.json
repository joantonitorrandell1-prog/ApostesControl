    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "nodemailer": "^8.0.11",
    "pg": "^8.11.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.11.5",
    "drizzle-kit": "^0.30.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
